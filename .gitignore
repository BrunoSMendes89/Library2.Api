## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.user
*.suo
*.userosscache
*.sln.docstates

# User-specific folders
.vscode/
.vs/
_UpgradeReport_Files/
Backup*/
UpgradeLog*.XML
UpgradeLog*.htm

# SQL Server files
*.mdf
*.ldf

# Azure Stream Analytics
*.azureFunctions/

# Mono Auto Generated Files
mono_crash.* 

# Windows image file caches
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Recycle Bin used on file shares
$RECYCLE.BIN/

# Windows Installer files
*.cab
*.msi
*.msm
*.msp

# Windows shortcuts
*.lnk

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Uncomment if you have tasks that create the project's static files in wwwroot
#wwwroot/

# Visual Studio workspace-related files
*.vspxproj.user
.vspscc
.vssscc
.idea/
.project
*.shfbproj.user

# Rider
.idea/
.idea_modules/

# Resharper
_ReSharper*/
*.DotSettings.User
resharper-internal/

# Coverlet
coverage.opencover.xml
coverage.cobertura.xml
coverage.json

# DotNet5+ 
.dotnet_temp/

# NCrunch
*.ncrunch*
NCrunchTemp_*/

# Code coverage results
*.coverage
*.coveragexml
_Reports/

# NUnit
*.nunit.*
*.VisualState.xml
TestResult.xml
TestResult/

# Build artifacts
publish/
out/

# Web-specific files
node_modules/
wwwroot/lib/

# Log files
*.log

# Local history
.localhistory/

# Temporary files
~$*
*.tmp
*.temp
*.tmpx
*.temp~

# IDE folders
.idea/
.idea_modules/
.idea/*/
*/.idea/
*/.idea_modules/
.vscode/
.vs/
